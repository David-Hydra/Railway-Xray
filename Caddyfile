{
    auto_https off
    admin off
    persist_config off
}

:{$PORT} {
    @vless_ws {
        path /{$UUID}-vless*
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @vless_ws 127.0.0.1:10000

    @vmess_ws {
        path /{$UUID}-vmess*
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @vmess_ws 127.0.0.1:10001

    @trojan_ws {
        path /{$UUID}-trojan*
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @trojan_ws 127.0.0.1:10002

    # Decoy site for non-proxy requests
    root * /usr/share/caddy
    file_server
}
